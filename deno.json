{
  "name": "@pointerbyte/denoforge",
  "version": "0.0.1",
  "description": "Deno port of GoForge: modular crypto, logging, security, jobs/workers and HTTP tooling.",
  "license": "Apache-2.0",
  "exports": {
    ".": "./mod.ts",
    "./encrypt": "./encrypt/mod.ts",
    "./encrypt/aws-kms": "./encrypt/aws-kms/mod.ts",
    "./encrypt/azure-key-vault": "./encrypt/azure-key-vault/mod.ts",
    "./encrypt/gcp-kms": "./encrypt/gcp-kms/mod.ts",
    "./logger": "./logger/mod.ts",
    "./security": "./security/mod.ts",
    "./tools": "./tools/mod.ts",
    "./config": "./config/mod.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.11",
    "@std/encoding": "jsr:@std/encoding@^1.0.7",
    "@std/http": "jsr:@std/http@^1.0.13",
    "@noble/hashes": "jsr:@noble/hashes@^1.7.1",
    "@grpc/grpc-js": "npm:@grpc/grpc-js@^1.12.0",
    "@grpc/proto-loader": "npm:@grpc/proto-loader@^0.7.13"
  },
  "tasks": {
    "check": "deno check mod.ts encrypt/aws-kms/mod.ts encrypt/azure-key-vault/mod.ts encrypt/gcp-kms/mod.ts examples/*.ts cmd/qdeno/main.ts cmd/deno-openssl/main.ts cmd/example/main.ts",
    "test": "deno test -A",
    "cov": "rm -rf coverage && deno test -A --coverage=coverage && deno coverage coverage",
    "cov:html": "deno coverage coverage --html",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "example:encrypt": "deno run examples/encrypt.ts",
    "example:jwt": "deno run examples/jwt.ts",
    "example:logger": "deno run examples/logger.ts",
    "example:tools": "deno run examples/tools.ts",
    "example:server": "deno run --allow-net examples/server.ts",
    "example:grpc": "deno run -A examples/grpc.ts",
    "example": "deno run -A cmd/example/main.ts",
    "qdeno": "deno run -A cmd/qdeno/main.ts",
    "deno-openssl": "deno run -A cmd/deno-openssl/main.ts"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window"]
  },
  "fmt": {
    "lineWidth": 100
  }
}
